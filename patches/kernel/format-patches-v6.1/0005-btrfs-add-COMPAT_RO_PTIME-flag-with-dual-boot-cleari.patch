From 7d52c10343e9098b95c343461932b0780944de07 Mon Sep 17 00:00:00 2001
From: Sean Smith <DefendTheDisabled@gmail.com>
Date: Thu, 9 Apr 2026 15:58:20 -0500
Subject: [PATCH 05/16] btrfs: add COMPAT_RO_PTIME flag with dual-boot clearing
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Adds BTRFS_FEATURE_COMPAT_RO_PTIME (1ULL << 4) as an advisory
feature flag marking a Btrfs filesystem as containing
ptime-populated inodes. Old kernels seeing this flag set would
refuse to RW mount (COMPAT_RO means "unknown flags block RW
mount") to prevent zeroing ptime on inode writes.

For local dual-boot safety, the patched kernel CLEARS this flag
on every RW mount in btrfs_start_pre_rw_mount(). This permits:
  - ptime kernel writes ptime values
  - unpatched LTS kernel (safety-net boot) can still RW mount
    the same filesystem
  - tradeoff: LTS kernel could zero ptime on specific files
    during emergency use (acceptable — LTS use is rare)

For upstream submission, the clearing logic would be removed,
restoring the COMPAT_RO semantics. This commit keeps both the
flag definition and the local-clearing behavior because they
are a matched pair: adding the flag without clearing breaks
LTS boot; clearing without adding the flag is pointless.

Ref: Decision #46 (disable COMPAT_RO_PTIME locally, re-enable upstream)
Files: fs/btrfs/disk-io.c:btrfs_start_pre_rw_mount
Files: fs/btrfs/fs.h (COMPAT_RO mask)
---
 fs/btrfs/disk-io.c         | 5 +++++
 fs/btrfs/fs.h              | 3 ++-
 include/uapi/linux/btrfs.h | 1 +
 3 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/fs/btrfs/disk-io.c b/fs/btrfs/disk-io.c
index 8df7eb7f01e9..ba5057c907fa 100644
--- a/fs/btrfs/disk-io.c
+++ b/fs/btrfs/disk-io.c
@@ -3011,6 +3011,11 @@ int btrfs_start_pre_rw_mount(struct btrfs_fs_info *fs_info)
 {
 	int ret;
 	const bool cache_opt = btrfs_test_opt(fs_info, SPACE_CACHE);
+
+	/* Clear PTIME compat_ro flag for local deployment.
+	 * This allows LTS/mainline kernels to boot normally.
+	 * Re-enable flag setting for upstream submission. */
+	btrfs_clear_fs_compat_ro(fs_info, PTIME);
 	bool rebuild_free_space_tree = false;
 
 	if (btrfs_test_opt(fs_info, CLEAR_CACHE) &&
diff --git a/fs/btrfs/fs.h b/fs/btrfs/fs.h
index 8ffbc40ebe45..7c8105ecf0c9 100644
--- a/fs/btrfs/fs.h
+++ b/fs/btrfs/fs.h
@@ -284,7 +284,8 @@ enum {
 	(BTRFS_FEATURE_COMPAT_RO_FREE_SPACE_TREE |	\
 	 BTRFS_FEATURE_COMPAT_RO_FREE_SPACE_TREE_VALID | \
 	 BTRFS_FEATURE_COMPAT_RO_VERITY |		\
-	 BTRFS_FEATURE_COMPAT_RO_BLOCK_GROUP_TREE)
+	 BTRFS_FEATURE_COMPAT_RO_BLOCK_GROUP_TREE | \
+	 BTRFS_FEATURE_COMPAT_RO_PTIME)
 
 #define BTRFS_FEATURE_COMPAT_RO_SAFE_SET	0ULL
 #define BTRFS_FEATURE_COMPAT_RO_SAFE_CLEAR	0ULL
diff --git a/include/uapi/linux/btrfs.h b/include/uapi/linux/btrfs.h
index e8fd92789423..d2c5424259d8 100644
--- a/include/uapi/linux/btrfs.h
+++ b/include/uapi/linux/btrfs.h
@@ -313,6 +313,7 @@ struct btrfs_ioctl_fs_info_args {
  * reducing mount time for large filesystem due to better locality.
  */
 #define BTRFS_FEATURE_COMPAT_RO_BLOCK_GROUP_TREE	(1ULL << 3)
+#define BTRFS_FEATURE_COMPAT_RO_PTIME			(1ULL << 4)
 
 #define BTRFS_FEATURE_INCOMPAT_MIXED_BACKREF	(1ULL << 0)
 #define BTRFS_FEATURE_INCOMPAT_DEFAULT_SUBVOL	(1ULL << 1)
