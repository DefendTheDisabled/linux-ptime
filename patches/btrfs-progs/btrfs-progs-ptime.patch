diff --git a/cmds/receive-dump.c b/cmds/receive-dump.c
index 89a4d567..1b19ee29 100644
--- a/cmds/receive-dump.c
+++ b/cmds/receive-dump.c
@@ -281,18 +281,46 @@ static int sprintf_timespec(struct timespec *ts, char *dest, int max_size)
 #define TIME_STRING_MAX	64
 static int print_utimes(const char *path, struct timespec *at,
 			struct timespec *mt, struct timespec *ct,
-			void *user)
+			struct timespec *pt, void *user)
 {
 	char at_str[TIME_STRING_MAX];
 	char mt_str[TIME_STRING_MAX];
 	char ct_str[TIME_STRING_MAX];
+	char pt_str[TIME_STRING_MAX];
 
 	if (sprintf_timespec(at, at_str, TIME_STRING_MAX - 1) < 0 ||
 	    sprintf_timespec(mt, mt_str, TIME_STRING_MAX - 1) < 0 ||
 	    sprintf_timespec(ct, ct_str, TIME_STRING_MAX - 1) < 0)
 		return -EINVAL;
-	return PRINT_DUMP(user, path, "utimes", "atime=%s mtime=%s ctime=%s",
-			  at_str, mt_str, ct_str);
+
+	/*
+	 * Three render cases for ptime:
+	 *   pt == NULL              : no ptime field (unpatched
+	 *                             sender — stream did not
+	 *                             carry BTRFS_SEND_A_PTIME)
+	 *   pt != NULL, value zero  : "ptime=unset" (explicit
+	 *                             clear from patched sender —
+	 *                             distinct from absent for
+	 *                             log forensics)
+	 *   pt != NULL, value !=0   : ptime=<formatted timespec>
+	 */
+	if (!pt) {
+		return PRINT_DUMP(user, path, "utimes",
+				  "atime=%s mtime=%s ctime=%s",
+				  at_str, mt_str, ct_str);
+	}
+
+	if (pt->tv_sec == 0 && pt->tv_nsec == 0) {
+		return PRINT_DUMP(user, path, "utimes",
+				  "atime=%s mtime=%s ctime=%s ptime=unset",
+				  at_str, mt_str, ct_str);
+	}
+
+	if (sprintf_timespec(pt, pt_str, TIME_STRING_MAX - 1) < 0)
+		return -EINVAL;
+	return PRINT_DUMP(user, path, "utimes",
+			  "atime=%s mtime=%s ctime=%s ptime=%s",
+			  at_str, mt_str, ct_str, pt_str);
 }
 
