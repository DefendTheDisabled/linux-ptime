@@ -368,6 +368,8 @@ static int read_and_process_cmd(struct btrfs_send_stream *sctx)
 	struct timespec at;
 	struct timespec ct;
 	struct timespec mt;
+	struct timespec pt;
+	struct timespec *ptp;
 	u8 uuid[BTRFS_UUID_SIZE];
 	u8 clone_uuid[BTRFS_UUID_SIZE];
 	u32 compression;
@@ -541,7 +543,22 @@ static int read_and_process_cmd(struct btrfs_send_stream *sctx)
 		TLV_GET_TIMESPEC(sctx, BTRFS_SEND_A_ATIME, &at);
 		TLV_GET_TIMESPEC(sctx, BTRFS_SEND_A_MTIME, &mt);
 		TLV_GET_TIMESPEC(sctx, BTRFS_SEND_A_CTIME, &ct);
-		ret = sctx->ops->utimes(path, &at, &mt, &ct, sctx->user);
+		/*
+		 * BTRFS_SEND_A_PTIME is optional. A patched sender on
+		 * proto >= 2 always emits it (even when zero, to
+		 * distinguish "explicit clear" from "absent"). An
+		 * unpatched sender or proto < 2 stream omits the
+		 * attribute entirely. cmd_attrs[].data is the
+		 * presence indicator (cleared per command via memset
+		 * at the top of read_and_process_cmd).
+		 */
+		if (sctx->cmd_attrs[BTRFS_SEND_A_PTIME].data) {
+			TLV_GET_TIMESPEC(sctx, BTRFS_SEND_A_PTIME, &pt);
+			ptp = &pt;
+		} else {
+			ptp = NULL;
+		}
+		ret = sctx->ops->utimes(path, &at, &mt, &ct, ptp, sctx->user);
 		break;
 	case BTRFS_SEND_C_UPDATE_EXTENT:
 		TLV_GET_STRING(sctx, BTRFS_SEND_A_PATH, &path);
