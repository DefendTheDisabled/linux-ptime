diff --git a/cmds/receive.c b/cmds/receive.c
index 1a4a043b..0e052881 100644
--- a/cmds/receive.c
+++ b/cmds/receive.c
@@ -20,6 +20,7 @@
 #include <sys/stat.h>
 #include <sys/ioctl.h>
 #include <sys/xattr.h>
+#include <sys/syscall.h>
 #include <linux/fs.h>
 #if HAVE_LINUX_FSVERITY_H
 #include <linux/fsverity.h>
@@ -37,6 +38,19 @@
 #include <string.h>
 #include <uuid/uuid.h>
 #include <zlib.h>
+
+/*
+ * Provenance time (ptime) is written via file_setattr(2),
+ * syscall 469 on x86_64 (kernel 6.17+). Prefer the libc/kernel
+ * symbol when available; fall back to the x86_64 number.
+ */
+#ifndef SYS_file_setattr
+#  ifdef __NR_file_setattr
+#    define SYS_file_setattr __NR_file_setattr
+#  else
+#    define SYS_file_setattr 469
+#  endif
+#endif
 #if COMPRESSION_LZO
 #include <lzo/lzoconf.h>
 #include <lzo/lzo1x.h>
@@ -969,7 +983,7 @@ out:
 
 static int process_utimes(const char *path, struct timespec *at,
 			  struct timespec *mt, struct timespec *ct,
-			  void *user)
+			  struct timespec *pt, void *user)
 {
 	int ret = 0;
 	struct btrfs_receive *rctx = user;
@@ -994,6 +1008,88 @@ static int process_utimes(const char *path, struct timespec *at,
 		goto out;
 	}
 
+	/*
+	 * Apply provenance time (ptime) via file_setattr(2) when the
+	 * sender provided a non-NULL pt pointer. NULL means the
+	 * stream did not carry BTRFS_SEND_A_PTIME (unpatched sender
+	 * or proto < 2) — in that case the destination file's
+	 * existing ptime is left untouched. A non-NULL pt with value
+	 * {0, 0} represents an explicit ptime clear from the sender
+	 * and is applied as ptime=0 on the destination.
+	 *
+	 * Skipping symlinks: file_setattr's notify_change ATTR_PTIME
+	 * path fails structurally on symlink inodes; the existing
+	 * cp/rsync/tar/borg patches all use flags=0 here. We lstat
+	 * to detect symlinks and skip them with a warning. ENOSYS
+	 * (kernel lacks file_setattr — LTS fallback boot) and
+	 * EOPNOTSUPP (filesystem doesn't support ptime setattr) are
+	 * soft failures: log and continue, since the snapshot is
+	 * structurally correct without ptime.
+	 */
+	if (pt) {
+		struct stat stbuf;
+		unsigned char fa[40];
+		long fs_ret;
+
+		if (lstat(full_path, &stbuf) < 0) {
+			ret = -errno;
+			error("utimes(ptime) lstat %s failed: %m", path);
+			goto out;
+		}
+
+		if (S_ISLNK(stbuf.st_mode)) {
+			if (bconf.verbose >= 2)
+				fprintf(stderr,
+					"ptime skipped on symlink %s\n",
+					path);
+			ret = 0;
+			goto out;
+		}
+
+		memset(fa, 0, sizeof(fa));
+		/*
+		 * struct file_attr VER1 layout (40 bytes):
+		 *   offset  0..23: VER0 fields (xflags, extsize,
+		 *                  nextents, projid, cowextsize) —
+		 *                  ALL ZERO so file_setattr stays
+		 *                  on the notify_change/iattr path
+		 *                  and does NOT dispatch to
+		 *                  vfs_fileattr_set (which on Btrfs
+		 *                  could clobber compression/nocow/
+		 *                  immutable/append xflags).
+		 *   offset 24..31: fa_ptime_sec  (__s64)
+		 *   offset 32..35: fa_ptime_nsec (__u32)
+		 *   offset 36..39: fa_ptime_pad  (__u32, must be 0)
+		 */
+		{
+			int64_t sec64 = (int64_t)pt->tv_sec;
+			uint32_t nsec32 = (uint32_t)pt->tv_nsec;
+
+			memcpy(fa + 24, &sec64, 8);
+			memcpy(fa + 32, &nsec32, 4);
+		}
+
+		fs_ret = syscall(SYS_file_setattr, AT_FDCWD, full_path,
+				 fa, (size_t)40, 0);
+		if (fs_ret < 0) {
+			int saved_errno = errno;
+
+			if (saved_errno == ENOSYS ||
+			    saved_errno == EOPNOTSUPP) {
+				if (bconf.verbose >= 1)
+					fprintf(stderr,
+						"ptime setattr unsupported by kernel or filesystem on %s, continuing without ptime preservation\n",
+						path);
+				ret = 0;
+				goto out;
+			}
+			ret = -saved_errno;
+			error("utimes(ptime) %s failed: %s", path,
+			      strerror(saved_errno));
+			goto out;
+		}
+	}
+
 out:
 	return ret;
 }
diff --git a/common/send-stream.c b/common/send-stream.c
index dacf0562..922e984e 100644
--- a/common/send-stream.c
