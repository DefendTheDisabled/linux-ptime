#
# FS QA Test No. btrfs/351
#
# Test Btrfs ptime rename-over guards.
# 1. nlink=1: rename-over with no-ptime source inherits target ptime
#    (the atomic save case).
# 2. nlink>1: rename-over still inherits target ptime (no nlink guard
#    in current implementation).
# 3. RENAME_EXCHANGE: ptimes swap with their inodes (no cross-contamination).
#
. ./common/preamble
_begin_fstest auto quick ptime

. ./common/ptime

_require_scratch_ptime

_scratch_mkfs >> $seqres.full 2>&1
_scratch_mount

dir=$SCRATCH_MNT/rename_guards

# --- Guard 1: nlink=1 rename-over inherits ptime ---
echo "--- nlink=1 rename-over ---"
mkdir -p $dir/g1
echo "target" > $dir/g1/target
_ptime_set $dir/g1/target 1560608400 0
echo "source" > $dir/g1/source
mv $dir/g1/source $dir/g1/target
sec=$(_ptime_get_sec $dir/g1/target)
echo "nlink=1 inherit: $sec"

# --- Guard 2: nlink>1 target ---
echo "--- nlink>1 target ---"
mkdir -p $dir/g2
echo "target" > $dir/g2/target
ln $dir/g2/target $dir/g2/hardlink
_ptime_set $dir/g2/target 1560608400 0
echo "source" > $dir/g2/source
mv $dir/g2/source $dir/g2/target
# source (no ptime) renamed over target (has ptime, nlink>1)
# current impl: ptime IS inherited even with nlink>1
sec_renamed=$(_ptime_get_sec $dir/g2/target)
sec_hardlink=$(_ptime_get_sec $dir/g2/hardlink)
echo "renamed file ptime (inherited from target): $sec_renamed"
echo "hardlink ptime (original inode): $sec_hardlink"

# --- Guard 3: RENAME_EXCHANGE ---
echo "--- RENAME_EXCHANGE ---"
mkdir -p $dir/g3
echo "A" > $dir/g3/fileA
echo "B" > $dir/g3/fileB
_ptime_set $dir/g3/fileA 1000000000 0
_ptime_set $dir/g3/fileB 2000000000 0

# Use renameat2 with RENAME_EXCHANGE
if $here/src/renameat2 -x $dir/g3/fileA $dir/g3/fileB >> $seqres.full 2>&1; then
    secA=$(_ptime_get_sec $dir/g3/fileA)
    secB=$(_ptime_get_sec $dir/g3/fileB)
    echo "After exchange fileA ptime: $secA"
    echo "After exchange fileB ptime: $secB"
else
    echo "renameat2 -x not available" >> $seqres.full
    _notrun "renameat2 RENAME_EXCHANGE not supported"
fi

_scratch_unmount
status=0
exit
